#!/bin/bash

case "$1" in
	hellokitty) 
		cp thema_configs/hello_kitty/hypr_kitty_config ~/.config/hypr/hyprland.conf
		cp thema_configs/hello_kitty/waybar_kitty_config ~/.config/waybar/style.css
		pkill waybar
		waybar > /dev/null 2>&1 & disown
		pkill swaybg
		swaybg -i "/home/kyksel3452/thema_changer/wallpaper/hello-kitty-pc-kbha8a5w146z68g0.jpg" -m fill > /dev/null 2>&1 &disown
